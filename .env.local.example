# Environment Variables for Vercel Deployment
# Copy this to .env.local and fill in your values
# NEVER commit .env.local to version control

# ========================================
# REQUIRED PRODUCTION VARIABLES
# ========================================

# Frontend Public URL (accessible in browser)
NEXT_PUBLIC_API_URL=https://your-app-name.vercel.app
# Description: The base URL for your deployed application
# Used by frontend for API calls and navigation

# Database Connection (PostgreSQL)
DATABASE_URL=postgresql://username:password@host:port/database_name
# Description: Full PostgreSQL connection string
# Format: postgresql://user:password@host:port/database
# Required for: User data, workflows, scoring, memory system

# OpenAI API Key
OPENAI_API_KEY=sk-your-openai-api-key-here
# Description: Your OpenAI API key for AI generation
# Get from: https://platform.openai.com/api-keys
# Required for: AI content generation, responses

# JWT Secret Key
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-long
# Description: Secret key for JWT token signing
# Must be: At least 32 characters long, random string
# Required for: User authentication, API security

# ========================================
# NEXT.JS CONFIGURATION
# ========================================

# Application Environment
NODE_ENV=production
# Description: Node.js environment (development/production)
# Used for: Optimizations, logging, feature flags

# Next.js Public URL
NEXT_PUBLIC_APP_URL=https://your-app-name.vercel.app
# Description: Public URL for Next.js app
# Used by: Client-side code, API calls

# ========================================
# OPTIONAL CONFIGURATION
# ========================================

# Redis Connection (Optional)
REDIS_URL=redis://user:password@host:port
# Description: Redis connection for caching/sessions
# Used for: Session storage, caching, rate limiting

# Logging Level
LOG_LEVEL=info
# Description: Logging verbosity (error, warn, info, debug)
# Used for: Application logging, monitoring

# ========================================
# VERCEL DEPLOYMENT NOTES
# ========================================

# For Vercel deployment:
# 1. Add these variables to Vercel Project Settings > Environment Variables
# 2. Set "Production" and "Preview" environments
# 3. DO NOT add NEXT_PUBLIC_* secrets to client-side code
# 4. Use Vercel dashboard for all sensitive values

# Security Notes:
# - NEXT_PUBLIC_* variables are exposed to browser
# - Keep API keys and secrets server-side only
# - Use different secrets for each environment
# - Rotate secrets regularly

# Example Production Values:
# NEXT_PUBLIC_API_URL=https://client-ai-system.vercel.app
# DATABASE_URL=postgresql://user:pass@db.vercel.app:5432/verceldb
# OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxx
# JWT_SECRET=super-secure-random-string-32-chars-min
