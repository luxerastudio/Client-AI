# Development Environment Variables
# All required variables for the strict config system

# SERVER CONFIGURATION
NODE_ENV=development
PORT=3002
HOST=0.0.0.0
BODY_LIMIT=10485760
KEEP_ALIVE_TIMEOUT=65000

# DATABASE CONFIGURATION
DATABASE_URL=postgresql://postgres:password@localhost:5432/agency_in_a_box_dev
DB_HOST=localhost
DB_PORT=5432
DB_NAME=agency_in_a_box_dev
DB_USER=postgres
DB_PASSWORD=password
DB_SSL=false
DB_MAX_CONNECTIONS=20
DB_CONNECTION_TIMEOUT=30000
DB_IDLE_TIMEOUT=10000

# AI CONFIGURATION
AI_PROVIDER=openai
OPENAI_API_KEY=sk-dev-key-for-testing-only
AI_API_KEY=sk-dev-key-for-testing-only
AI_MODEL=gpt-3.5-turbo
AI_MAX_TOKENS=1000
AI_TEMPERATURE=0.7
AI_TIMEOUT=30000
AI_RETRY_ATTEMPTS=3
AI_RATE_LIMIT_PER_MINUTE=60

# WORKFLOW CONFIGURATION
MAX_CONCURRENT_WORKFLOWS=10
WORKFLOW_DEFAULT_TIMEOUT=300000
WORKFLOW_MAX_STEPS=100
WORKFLOW_CHECKPOINT_INTERVAL=5000
WORKFLOW_ENABLE_PERSISTENCE=true
WORKFLOW_STORAGE_PATH=./tmp/workflows

# SCORING CONFIGURATION
SCORING_ALGORITHM=weighted
SCORING_WEIGHT_RELEVANCE=0.4
SCORING_WEIGHT_QUALITY=0.3
SCORING_WEIGHT_ENGAGEMENT=0.3
SCORING_WEIGHT_CONVERSION=0.0
SCORING_CACHE_ENABLED=true
SCORING_CACHE_TTL=300000
SCORING_BATCH_SIZE=100

# VERSIONING CONFIGURATION
VERSIONING_ENABLED=true
VERSIONING_MAX_VERSIONS=10
VERSIONING_AUTO_VERSIONING=false
VERSIONING_STORAGE_PATH=./tmp/versions
VERSIONING_COMPRESSION_ENABLED=false

# USER MEMORY CONFIGURATION
USER_MEMORY_MAX_PROMPT_HISTORY=1000
USER_MEMORY_MAX_INTERACTION_HISTORY=5000
USER_MEMORY_PATTERN_DETECTION_THRESHOLD=0.7
USER_MEMORY_ADAPTATION_CONFIDENCE_THRESHOLD=0.8
USER_MEMORY_PERSONALIZATION_ENABLED=true
USER_MEMORY_AUTO_ADAPTATION=true
USER_MEMORY_RETENTION_PERIOD=2592000000
USER_MEMORY_STORAGE_PATH=./tmp/memory

# SECURITY CONFIGURATION
SECURITY_CONFIG_PATH=./config/security.json
SECURITY_HOT_RELOAD=false

# LOGGING CONFIGURATION
LOGGING_ENABLED=true
LOG_LEVEL=info
LOG_FORMAT=json
LOG_FILE_ENABLED=true
LOG_FILE_PATH=./logs/app.log
LOG_MAX_FILE_SIZE=10485760
LOG_MAX_FILES=5
LOG_CONSOLE_ENABLED=true

# METRICS CONFIGURATION
METRICS_ENABLED=true
METRICS_PORT=9090
METRICS_PATH=/metrics
METRICS_COLLECT_DEFAULT=true
METRICS_COLLECT_INTERVAL=10000

# REDIS CONFIGURATION (optional for development)
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=ai_client:
REDIS_MAX_RETRIES=3
REDIS_RETRY_DELAY=1000

# CACHE CONFIGURATION
CACHE_PROVIDER=memory
CACHE_TTL=300000
CACHE_MAX_SIZE=1000
CACHE_CHECK_PERIOD=300000

# JWT CONFIGURATION
JWT_SECRET=dev-super-secret-jwt-key-min-32-chars-long-for-testing-only

# FRONTEND URL FOR CORS
FRONTEND_URL=http://localhost:3000
