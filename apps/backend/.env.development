# Development Environment Variables
NODE_ENV=development
PORT=3002

# Database Configuration (using mock mode for development)
DATABASE_URL=

# Redis Configuration (optional for development)
REDIS_URL=

# OpenAI Configuration (add your key if needed)
OPENAI_API_KEY=

# JWT Configuration
JWT_SECRET=dev-secret-key-for-testing-only
JWT_EXPIRES_IN=7d

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=15m

# Logging
LOG_LEVEL=info

# AI Configuration
AI_MODEL=gpt-3.5-turbo
AI_MAX_TOKENS=1000
AI_TEMPERATURE=0.7

# Scoring Configuration
SCORING_ALGORITHM=weighted
SCORING_WEIGHT_RELEVANCE=0.4
SCORING_WEIGHT_QUALITY=0.3
SCORING_WEIGHT_ENGAGEMENT=0.3

# Versioning Configuration
VERSIONING_ENABLED=true
VERSIONING_MAX_VERSIONS=10

# Security Configuration
SECURITY_ENABLED=true
CORS_ORIGIN=http://localhost:3000,http://localhost:3001
HELMET_ENABLED=true

# Frontend URL for CORS
FRONTEND_URL=http://localhost:3000
