# Database
DATABASE_URL="postgresql://username:password@localhost:5432/ai_saas"

# Redis
REDIS_URL="redis://localhost:6379"

# OpenAI
OPENAI_API_KEY="your-openai-api-key"

# Server
PORT=3001
NODE_ENV="development"

# JWT
JWT_SECRET="your-jwt-secret"
JWT_EXPIRES_IN="7d"

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW="15m"

# Logging
LOG_LEVEL="info"
