Content-Type: {{contentType}}

{
  "content": "Dear team, I'm excited to share our quarterly results. We've achieved significant growth across all key metrics.",
  "config": {
    "maxVersions": 2,
    "autoSelect": true,
    "targetQuality": 8.0
