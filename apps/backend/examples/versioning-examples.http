### 25. Generic Quick Generation
POST {{baseUrl}}/versioning/quick-generate
Content-Type: {{contentType}}

{
  "content": "The future of work is being reshaped by artificial intelligence and automation. Companies that adapt quickly will thrive in this new landscape.",
  "contentType": "seo_article",
  "config": {
    "maxVersions": 3,
    "enableImprovementLoop": true,
    "targetQuality": 8.0
  }
}

### 26. Create Template
POST {{baseUrl}}/versioning/templates
Content-Type: {{contentType}}

{
  "name": "Blog Post Template",
  "description": "Template for generating high-quality blog posts with multiple versions",
  "config": {
    "maxVersions": 4,
    "strategy": "improvement",
    "selectionCriteria": "quality",
    "improvementThreshold": 7.5,
    "enableComparison": true,
    "autoSelect": false,
    "retainAllVersions": true
  },
  "promptTemplate": "Generate a blog post about {topic} for {targetAudience}. The tone should be {tone} and include {keywords}.",
  "variationStrategies": ["different_tone", "different_structure", "different_focus"],
  "qualityThresholds": {
    "minimum": 7.0,
    "excellent": 8.5
  }
}

### 27. Get All Templates
GET {{baseUrl}}/versioning/templates

### 28. Get Specific Template
GET {{baseUrl}}/versioning/templates/TEMPLATE_ID

### 29. Update Template
PUT {{baseUrl}}/versioning/templates/TEMPLATE_ID
Content-Type: {{contentType}}

{
  "name": "Updated Blog Post Template",
  "description": "Enhanced template with better variation strategies",
  "config": {
    "maxVersions": 5,
    "strategy": "parallel",
    "improvementThreshold": 8.0
  }
}

### 30. Delete Template
DELETE {{baseUrl}}/versioning/templates/TEMPLATE_ID

### 31. Get System Information
GET {{baseUrl}}/versioning/info

### 32. Complex Workflow Example - Sequential Strategy
POST {{baseUrl}}/versioning/requests
Content-Type: {{contentType}}

{
  "input": {
    "content": "Machine learning models are becoming more sophisticated and capable of handling complex tasks. From natural language processing to computer vision, AI is transforming industries.",
    "context": {
      "targetAudience": "technical professionals",
      "purpose": "educational overview",
      "keywords": ["machine learning", "AI", "neural networks", "deep learning"],
      "tone": "technical but accessible"
    }
  },
  "config": {
    "maxVersions": 4,
    "strategy": "sequential",
    "selectionCriteria": "quality",
    "improvementThreshold": 7.5,
    "enableComparison": true,
    "autoSelect": false,
    "retainAllVersions": true,
    "enableImprovementLoop": true,
    "maxImprovementIterations": 2,
    "targetQuality": 8.5
  }
}

### 33. Complex Workflow Example - Parallel Strategy
POST {{baseUrl}}/versioning/requests
Content-Type: {{contentType}}

{
  "input": {
    "content": "Digital marketing strategies must evolve to meet changing consumer behaviors. Social media, content marketing, and SEO are all critical components of a successful online presence.",
    "context": {
      "targetAudience": "marketing managers",
      "purpose": "strategic guidance",
      "keywords": ["digital marketing", "social media", "SEO", "content marketing"],
      "tone": "strategic and actionable"
    }
  },
  "config": {
    "maxVersions": 5,
    "strategy": "parallel",
    "selectionCriteria": "quality",
    "improvementThreshold": 7.0,
    "enableComparison": true,
    "autoSelect": false,
    "retainAllVersions": true,
    "generateVariations": true,
    "variationCount": 2
  }
}

