### 45. Advanced Search with Multiple Criteria
GET {{baseUrl}}/versioning/versions/search?status=selected&minQualityScore=8&maxQualityScore=10&tags=improved,best&dateStart=2024-01-01&dateEnd=2024-12-31

### 46. Version Management Workflow - Complete Example
# Step 1: Create request
POST {{baseUrl}}/versioning/requests
Content-Type: {{contentType}}

{
  "input": {
    "content": "Artificial intelligence is revolutionizing healthcare delivery systems worldwide.",
    "context": {
      "targetAudience": "healthcare professionals",
      "purpose": "educational overview",
      "keywords": ["AI", "healthcare", "medical technology", "patient care"],
      "tone": "professional and informative"
    }
  },
  "config": {
    "maxVersions": 3,
    "strategy": "sequential",
    "selectionCriteria": "quality",
    "improvementThreshold": 7.5,
    "enableComparison": true,
    "autoSelect": false,
    "retainAllVersions": true
  }
}

###

# Step 2: Generate versions (replace REQUEST_ID from step 1 response)
POST {{baseUrl}}/versioning/requests/REQUEST_ID/generate

###

# Step 3: Compare versions
POST {{baseUrl}}/versioning/requests/REQUEST_ID/compare
Content-Type: {{contentType}}

{
  "versionIds": ["VERSION_ID_1", "VERSION_ID_2", "VERSION_ID_3"],
  "criteria": ["quality", "content"]
}

###

# Step 4: Select best version
POST {{baseUrl}}/versioning/requests/REQUEST_ID/select-best
Content-Type: {{contentType}}

{
  "criteria": "quality"
}

###

# Step 5: Run improvement loop if needed
POST {{baseUrl}}/versioning/requests/REQUEST_ID/improve
Content-Type: {{contentType}}

{
  "maxIterations": 2,
  "targetQuality": 8.5
}

###

# Step 6: Get final results
GET {{baseUrl}}/versioning/requests/REQUEST_ID/selected

### 47. Template-Based Version Generation
# First create a template
POST {{baseUrl}}/versioning/templates
Content-Type: {{contentType}}

{
  "name": "Marketing Content Template",
  "description": "Template for generating marketing content with multiple variations",
  "config": {
    "maxVersions": 4,
    "strategy": "variation",
    "selectionCriteria": "quality",
    "improvementThreshold": 7.0,
    "enableComparison": true,
    "autoSelect": false,
    "retainAllVersions": true
  },
  "promptTemplate": "Create compelling marketing content about {product} for {audience}. Focus on {benefits} and use {tone} tone.",
  "variationStrategies": ["different_tone", "different_focus", "different_style"],
  "qualityThresholds": {
    "minimum": 7.0,
    "excellent": 8.5
  }
}

###

# Then use the template for generation
POST {{baseUrl}}/versioning/quick-generate
Content-Type: {{contentType}}

{
  "content": "Our innovative AI-powered analytics platform helps businesses make data-driven decisions with ease.",
  "contentType": "ad_copy",
  "config": {
    "templateId": "TEMPLATE_ID",
    "templateVariables": {
      "product": "AI analytics platform",
      "audience": "business executives",
      "benefits": "cost savings, efficiency gains, competitive advantage",
      "tone": "persuasive and professional"
    }
  }
}
