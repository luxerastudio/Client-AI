  }
}

### 14. Get Execution Status
GET {{baseUrl}}/workflow-engine/executions/EXECUTION_ID

### 15. Get All Executions
GET {{baseUrl}}/workflow-engine/executions

### 16. Get Executions for Template
GET {{baseUrl}}/workflow-engine/executions?templateId=youtube-script-generator

### 17. Cancel Execution
POST {{baseUrl}}/workflow-engine/executions/EXECUTION_ID/cancel

### 18. Retry Failed Execution
POST {{baseUrl}}/workflow-engine/executions/EXECUTION_ID/retry

### 19. Get System Information
GET {{baseUrl}}/workflow-engine/system/info

### 20. Update Template
PUT {{baseUrl}}/workflow-engine/templates/youtube-script-generator
Content-Type: {{contentType}}

{
  "description": "Updated description for YouTube script generator",
  "metadata": {
    "version": "1.1.0",
    "lastUpdated": "2024-01-01"
  }
}

### 21. Delete Template
DELETE {{baseUrl}}/workflow-engine/templates/TEMPLATE_ID

### 22. Complex Custom Workflow - Marketing Campaign
POST {{baseUrl}}/workflow-engine/templates
Content-Type: {{contentType}}

{
  "name": "Marketing Campaign Generator",
  "description": "Creates complete marketing campaigns with multiple content types",
  "category": "marketing",
  "tags": ["marketing", "campaign", "content", "strategy"],
  "steps": [
    {
      "id": "analyze_market",
      "type": "analyze_input",
      "name": "Analyze Market & Audience",
      "order": 0,
      "dependencies": [],
      "config": {
        "analysisType": "marketing",
        "focus": "campaign_strategy"
      }
    },
    {
      "id": "structure_campaign",
      "type": "breakdown_structure",
      "name": "Structure Campaign Components",
      "order": 1,
      "dependencies": ["analyze_market"],
      "config": {
        "structureType": "marketing_campaign",
        "includeTimeline": true
      }
    },
    {
      "id": "generate_email_sequence",
      "type": "generate_output",
      "name": "Generate Email Sequence",
      "order": 2,
      "dependencies": ["structure_campaign"],
      "config": {
        "outputType": "email",
        "sequenceLength": 5
      }
    },
    {
      "id": "generate_social_posts",
      "type": "generate_output",
      "name": "Generate Social Media Posts",
      "order": 2,
      "dependencies": ["structure_campaign"],
      "config": {
        "outputType": "social_media",
        "platformCount": 3
      }
    },
    {
      "id": "refine_campaign",
      "type": "refine_output",
      "name": "Refine Campaign Materials",
      "order": 3,
      "dependencies": ["generate_email_sequence", "generate_social_posts"],
      "config": {
        "refinementType": "engagement",
        "targetTone": "persuasive"
      }
    }
  ],
  "inputSchema": {
    "type": "object",
    "required": ["product", "campaignGoal", "duration"],
    "properties": {
      "product": { "type": "string" },
      "campaignGoal": { "type": "string" },
      "duration": { "type": "string" },
      "targetAudience": { "type": "string" },
      "budget": { "type": "number" },
      "platforms": { "type": "array", "items": { "type": "string" } }
    }
  }
}

### 23. Execute Marketing Campaign Workflow
POST {{baseUrl}}/workflow-engine/execute/marketing-campaign-generator
Content-Type: {{contentType}}

{
  "input": {
    "product": "Eco-Friendly Water Bottle",
    "campaignGoal": "Increase brand awareness and drive sales",
    "duration": "30 days",
    "targetAudience": "Eco-conscious consumers",
    "budget": 5000,
    "platforms": ["Instagram", "Facebook", "Email"]
  }
}

