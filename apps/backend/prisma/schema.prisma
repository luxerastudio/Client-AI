// Simplified Prisma schema for essential functionality only

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Lead {
  id          String   @id @default(cuid())
  niche       String
  location    String
  businessName String?
  contactPerson String?
  email       String?
  phone       String?
  painPoint   String?
  generatedAt DateTime @default(now())
  userId      String?

  @@map("leads")
}
