// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Workflow {
  id          String   @id @default(cuid())
  name        String
  type        String
  status      String
  userId      String
  steps       Json
  definition  Json?
  config      Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("workflows")
}

model AIWorkflow {
  id           String   @id @default(cuid())
  name         String
  description  String?
  type         String
  status       String
  steps        Json
  modelConfig  Json
  inputSchema  Json
  outputSchema Json
  metadata     Json?
  userId       String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("ai_workflows")
}

model WorkflowExecution {
  id          String   @id @default(cuid())
  workflowId  String
  status      String
  input       Json
  output      Json?
  error       String?
  startedAt   DateTime @default(now())
  completedAt DateTime?
  metadata    Json?
  stepResults Json?
  results     Json?
  metrics     Json?

  @@map("workflow_executions")
}
