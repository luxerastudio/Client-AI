{
  "name": "@repo/frontend",
  "version": "1.0.0",
  "description": "AI Client Acquisition System - Frontend (Next.js)",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3001",
    "dev:clean": "rm -rf .next && next dev --port 3001",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "next lint --max-warnings=0 || true",
    "type-check": "tsc --noEmit || true",
    "clean": "rm -rf .next node_modules",
    "predev": "cd ../../ && ./scripts/cleanup-ports.sh && echo 'Starting frontend dev server on port 3001...'"
  },
  "dependencies": {
    "next": "^16.2.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "jsonwebtoken": "^9.0.3",
    "tailwindcss": "^3.3.0",
    "postcss": "^8",
    "autoprefixer": "^10.0.1",
    "typescript": "^5",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/node": "^20",
    "@types/jsonwebtoken": "^9.0.10"
  },
  "devDependencies": {}
}
