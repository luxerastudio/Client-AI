{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./.next",
    "composite": false,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ],
      "@repo/*": [
        "../../packages/*"
      ],
      "@repo/core": [
        "../../packages/core/core"
      ],
      "@repo/shared": [
        "../../packages/shared"
      ],
      "@/lib/*": [
        "./lib/*"
      ],
      "@/lib": [
        "./lib"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    ".next"
  ]
}
