{
  "name": "@repo/root",
  "version": "1.0.0",
  "description": "AI Client Acquisition System - Monorepo Workspace",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "pnpm --parallel dev",
    "build": "pnpm -r build",
    "build:clean": "rm -rf node_modules pnpm-lock.yaml && pnpm install && pnpm build",
    "start": "pnpm --parallel start",
    "lint": "pnpm -r lint",
    "type-check": "pnpm -r type-check",
    "test": "pnpm -r test",
    "clean": "pnpm -r clean && rm -rf node_modules pnpm-lock.yaml",
    "postinstall": "echo 'Workspace dependencies installed successfully'"
  },
  "keywords": [
    "client-acquisition",
    "business-engine",
    "lead-generation",
    "revenue-automation",
    "agency",
    "monorepo"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/node": "^20",
    "typescript": "^5"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^5.2.1"
  }
}
