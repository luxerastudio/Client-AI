{
  "version": 2,
  "framework": "nextjs",
  "installCommand": "pnpm install --no-frozen-lockfile",
  "buildCommand": "cd apps/frontend && pnpm build",
  "outputDirectory": "apps/frontend/.next",
  "functions": {
    "app/api/test/route.ts": {
      "maxDuration": 30
    },
    "app/api/**/*.ts": {
      "maxDuration": 30
    }
  },
  "build": {
    "env": {
      "NEXT_PUBLIC_API_URL": "https://client-acquisition-system-ai.vercel.app",
      "NEXT_PUBLIC_ENV": "production",
      "BACKEND_URL": "https://client-acquisition-system-ai.vercel.app"
    }
  }
}
